    def _final_analysis_no_sqrt(self):
        """
        无平方根版本的最终分析
        """
        print("\n" + "=" * 60)
        print("最终分析（无平方根版本）")
        print("=" * 60)
        
        G_g_cpu = self.G_g_n_cpu
        
        # 统计分布
        very_flat = np.sum(G_g_cpu < -0.8)
        flat = np.sum((G_g_cpu >= -0.8) & (G_g_cpu < -0.5))
        slightly_bumpy = np.sum((G_g_cpu >= -0.5) & (G_g_cpu < -0.2))
        bumpy = np.sum(G_g_cpu >= -0.2)
        
        total = len(G_g_cpu)
        
        print(f"几何梯度分布（无平方根）：")
        print(f"  非常平坦 (<-0.8): {very_flat}点 ({very_flat/total*100:.1f}%)")
        print(f"  平坦 (-0.8~-0.5): {flat}点 ({flat/total*100:.1f}%)")
        print(f"  轻微凹凸 (-0.5~-0.2): {slightly_bumpy}点 ({slightly_bumpy/total*100:.1f}%)")
        print(f"  凹凸/边缘 (≥-0.2): {bumpy}点 ({bumpy/total*100:.1f}%)")
        
        print(f"\n总结（无平方根版本）：")
        print(f"  1. 不使用平方根变换，曲率直接映射到几何梯度")
        print(f"  2. 平坦区域和凹凸区域的映射关系保持不变：")
        print(f"     平坦→G_g接近-1，凹凸→G_g接近0")
        print(f"  3. 平坦区域的微小差异不会被放大")
        print(f"  4. 适用于曲率分布相对均匀的场景")

# ------------------------------ 比较函数 ------------------------------
def compare_sqrt_vs_no_sqrt():
    """
    比较平方根版本和无平方根版本的区别
    """
    print("\n" + "=" * 70)
    print("平方根版本 vs 无平方根版本 对比分析")
    print("=" * 70)
    
    print("\n主要区别：")
    print("1. 平方根版本（原版）：")
    print("   - 使用 curv_transformed = √(curv_norm)")
    print("   - 放大低曲率区（平坦区域）的差异")
    print("   - 压缩高曲率区（凹凸区域）的差异")
    print("   - 适用于大部分区域平坦的点云")
    
    print("\n2. 无平方根版本（本版）：")
    print("   - 使用 curv_transformed = curv_norm（直接映射）")
    print("   - 保持线性关系")
    print("   - 平坦和凹凸区域的权重相等")
    print("   - 适用于曲率分布均匀的点云")
    
    print("\n数值示例对比：")
    print(f"{'曲率':<8} {'平方根版G_g':<15} {'无平方根版G_g':<15} {'解释':<20}")
    print("-" * 60)
    
    test_curvatures = [0.01, 0.04, 0.09, 0.25, 0.49, 0.81, 1.00]
    
    for curv in test_curvatures:
        # 平方根版本
        sqrt_transformed = np.sqrt(curv)
        G_g_sqrt = - (1.0 - sqrt_transformed)
        
        # 无平方根版本
        G_g_no_sqrt = - (1.0 - curv)
        
        if curv < 0.1:
            explanation = "平坦区域"
        elif curv < 0.5:
            explanation = "中等区域"
        else:
            explanation = "凹凸区域"
        
        print(f"{curv:<8.3f} {G_g_sqrt:<15.3f} {G_g_no_sqrt:<15.3f} {explanation:<20}")

